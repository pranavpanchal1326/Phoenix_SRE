# Phoenix SRE Configuration Template
# Copy this to .env and fill in your values

# ============================================
# GOOGLE CLOUD CONFIGURATION
# ============================================
GCP_PROJECT=phoenix-sre-marathon
GCP_REGION=europe-west1
GCP_BILLING_ACCOUNT_ID=your-billing-account-id

# ============================================
# GEMINI API CONFIGURATION
# ============================================
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# AI Model Configuration
GEMINI_PRIMARY_MODEL=gemini-2.0-flash-exp
GEMINI_FALLBACK_MODEL=gemini-1.5-flash-latest
GEMINI_PREMIUM_MODEL=gemini-1.5-pro-latest

# ============================================
# CLOUD RUN SERVICES (Optional)
# ============================================
# Leave empty if not using real Cloud Run services
ADK_AGENT_URL=
GEMMA_GPU_URL=

# ============================================
# FIRESTORE CONFIGURATION
# ============================================
FIRESTORE_COLLECTION_INCIDENTS=incidents
FIRESTORE_COLLECTION_SCALING=scaling_events
FIRESTORE_COLLECTION_METRICS=metrics_snapshots

# ============================================
# APPLICATION SETTINGS
# ============================================
# Mode: "live" or "chaos" (chaos = simulation mode)
APP_MODE=chaos

# Enable/Disable Features
ENABLE_3D_TOPOLOGY=false
ENABLE_VOICE_ALERTS=false
ENABLE_SLACK_NOTIFICATIONS=false

# ============================================
# OPTIONAL INTEGRATIONS
# ============================================
SLACK_BOT_TOKEN=
SLACK_CHANNEL=#phoenix-alerts
GOOGLE_SHEET_ID=

# ============================================
# COST & BUDGET SETTINGS
# ============================================
BUDGET_LIMIT_USD=10.00
COST_ALERT_THRESHOLD_PERCENT=90

# ============================================
# DEMO SETTINGS
# ============================================
DEMO_MODE_DURATION_SECONDS=90
DEMO_AUTO_ADVANCE=true
